# Supabase Configuration (new key format)
# Get these values from your Supabase Dashboard -> Connect -> App Frameworks
# or Dashboard -> Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://gyxcdrcdnnzjdmcrwbpr.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Data Backend: "localStorage" (default, no Supabase needed) or "supabase"
NEXT_PUBLIC_DATA_BACKEND=localStorage

# Playwright remote POS E2E
E2E_POS_BASE_URL=http://127.0.0.1:4010
E2E_RUN_ID=

# Delivery integration for P24 refunds
DELIVERY_API_URL=http://127.0.0.1:3001
DELIVERY_INTERNAL_API_KEY=change-me

# Optional Sentry build config (runtime DSN is configured in code)
SENTRY_ORG=pirxey
SENTRY_PROJECT=meso-pos
SENTRY_AUTH_TOKEN=sntrys_...
